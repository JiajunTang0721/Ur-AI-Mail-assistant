const syncAnalysisHistory = (items: MailItem[], generatedAt: string) => {
  const nextHistory = { ...state.analysisHistory }

  items.forEach((item) => {
    const previous = nextHistory[item.messageId]

    nextHistory[item.messageId] = {
      messageId: item.messageId,
      threadId: item.threadId,
      senderName: item.senderName,
      senderEmail: item.senderEmail,
      subject: item.subject,
      briefSubject: item.briefSubject,
      summary: item.summary,
      aiSummary: item.aiSummary,
      aiReason: item.aiReason,
      actionLabel: item.actionLabel,
      reasonTags: item.reasonTags,
      focusAreas: item.focusAreas,
      aggregationKey: item.aggregationKey,
      aggregationLabel: item.aggregationLabel,
      priority: item.priority,
      tab: item.tab,
      isHighPriority: item.isHighPriority,
      isTodo: item.isTodo,
      isDueSoon: item.isDueSoon,
      isIgnorable: item.isIgnorable,
      sortScore: item.sortScore,
      deadlineLabel: item.deadlineLabel,
      openedCount: previous?.openedCount ?? state.clickCounts[item.senderName] ?? 0,
      processed: previous?.processed ?? state.processedMessageIds.includes(item.messageId),
      feedback: previous?.feedback,
      lastAnalyzedAt: generatedAt,
    }
  })

  const trimmedEntries = Object.values(nextHistory)
    .sort(
      (left, right) =>
        new Date(right.lastAnalyzedAt).getTime() - new Date(left.lastAnalyzedAt).getTime(),
    )
    .slice(0, 1000)

  state.analysisHistory = Object.fromEntries(
    trimmedEntries.map((entry) => [entry.messageId, entry]),
  )
}

