const buildMailItemFromRow = (row: HTMLElement, index: number): MailItem | null => {
  const threadId = row.getAttribute('data-legacy-thread-id') ?? `thread-${index}`
  const messageId = row.getAttribute('data-legacy-message-id') ?? threadId
  const senderEl =
    row.querySelector<HTMLElement>('.yP') ??
    row.querySelector<HTMLElement>('.yW span[email]') ??
    row.querySelector<HTMLElement>('.yW')
  const subjectEl =
    row.querySelector<HTMLElement>('.bog') ??
    row.querySelector<HTMLElement>('.y6') ??
    row.querySelector<HTMLElement>('span[id]')
  const summaryEl = row.querySelector<HTMLElement>('.y2')
  const timeEl = row.querySelector<HTMLElement>('.xW span') ?? row.querySelector<HTMLElement>('.xW')

  const senderName =
    senderEl?.getAttribute('name') ??
    senderEl?.getAttribute('email') ??
    extractText(senderEl)
  const senderEmail = senderEl?.getAttribute('email') ?? undefined
  const subject = extractText(subjectEl)
  const summary = extractText(summaryEl)
  const timeText = timeEl?.getAttribute('title') ?? extractText(timeEl)

  if (!senderName && !subject) {
    return null
  }

  const contentText = `${senderName} ${senderEmail ?? ''} ${subject} ${summary}`
  const unread = row.classList.contains('zE')
  const actionLabel = getActionLabel(contentText)
  const focusAreas = getFocusAreas(contentText)
  const deadlineLabel = extractDeadlineLabel(`${subject} ${summary}`)
  const senderPreference = getSenderPreference(senderName)
  const { priority, tab, isHighPriority, isTodo, isDueSoon, isIgnorable } = classifyMail({
    text: contentText,
    unread,
    actionLabel,
    focusAreas,
    hasDeadline: Boolean(deadlineLabel),
    senderPreference,
  })
  const reasonTags = Array.from(
    new Set(
      [
        actionLabel,
        deadlineLabel ? '鏈夋椂闂寸偣' : undefined,
        ...focusAreas,
      ].filter(Boolean),
    ),
  ).slice(0, 3) as string[]
  const { briefSubject, aiSummary, aiReason } = buildAiInsight({
    senderName,
    subject,
    summary,
    actionLabel,
    deadlineLabel,
    focusAreas,
    priority,
  })

  return {
    messageId,
    threadId,
    senderName,
    senderEmail,
    subject: subject || '(鏃犳爣棰橀偖浠?',
    briefSubject,
    summary: summary || '褰撳墠閭欢鍒楄〃鏈彁渚涙憳瑕侊紝鍙偣鍑绘煡鐪嬪師閭欢銆?,
    aiSummary,
    aiReason,
    deadlineLabel,
    timeText: timeText || '鏈€杩?,
    priority,
    tab,
    isHighPriority,
    isTodo,
    isDueSoon,
    isIgnorable,
    actionLabel,
    reasonTags,
    focusAreas,
    aggregationKey: isNewsletterLike(contentText) ? normalize(senderName) : undefined,
    sortScore: priority === 'high' ? 80 : priority === 'medium' ? 45 : 10,
  }
}

