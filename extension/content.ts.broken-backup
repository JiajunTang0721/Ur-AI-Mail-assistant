    root.remove()
  }

  for (const staleRoot of Array.from(document.querySelectorAll<HTMLElement>(`#${ROOT_ID}`))) {
    staleRoot.remove()
  }

  root = document.createElement('div')
  root.id = ROOT_ID
  root.dataset.instanceId = INSTANCE_ID
  document.body.appendChild(root)

  root.addEventListener(
    'wheel',
    (event) => {
      if ((event.target as HTMLElement).closest('.lma-ext-panel')) {
        event.stopPropagation()
      }
    },
    { passive: true },
  )

  root.addEventListener('pointerdown', (event) => {
    if ((event.target as HTMLElement).closest('.lma-ext-panel')) {
      event.stopPropagation()
    }
  })

  root.addEventListener('click', (event) => {
    const target = (event.target as HTMLElement).closest<HTMLElement>('[data-action]')
    if (!target) {
      return
    }

    const action = target.dataset.action

    if (action === 'toggle-panel') {
      if (state.isOpen) {
        state.isOpen = false
        render()
      } else {
        void openPanel()
      }
      return
    }

    if (action === 'close-panel') {
      state.isOpen = false
      render()
      return
    }

    if (action === 'switch-tab') {
      const tab = target.dataset.tab as TabKey | undefined
      if (tab) {
        state.activeTab = tab
        state.expandedBundleKey = null
        syncPersistedState()
        render()
      }
      return
    }

    if (action === 'toggle-bundle') {
      const bundleKey = target.dataset.bundleKey
      if (bundleKey) {
        state.expandedBundleKey = state.expandedBundleKey === bundleKey ? null : bundleKey
        render()
      }
      return
    }

    if (action === 'toggle-filter-section') {
      const section = target.dataset.section as FilterSectionKey | undefined
      if (section) {
        state.expandedSections = {
          ...state.expandedSections,
          [section]: !state.expandedSections[section],
        }
        render()
      }
      return
    }

    if (action === 'toggle-sender') {
      const value = target.dataset.value
      if (value) {
        state.selectedSenders = toggleSelection(state.selectedSenders, value)
        syncPersistedState()
        markNeedsRerank()
        render()
      }
      return
    }

    if (action === 'toggle-focus') {
      const value = target.dataset.value
      if (value) {
        state.selectedFocuses = toggleSelection(state.selectedFocuses, value)
        syncPersistedState()
        markNeedsRerank()
        render()
      }
      return
    }

    if (action === 'add-custom-sender') {
      const value = state.customSenderValue.trim()
      if (!value) {
        return
      }

      if (!state.customSenderEntries.includes(value)) {
        state.customSenderEntries = [...state.customSenderEntries, value]
      }

      state.selectedSenders = Array.from(new Set([...state.selectedSenders.filter((item) => item !== CUSTOM_SENDER), value]))
      state.customSenderValue = ''
      syncPersistedState()
      markNeedsRerank()
      render()
      return
    }

    if (action === 'add-custom-focus') {
      const value = state.customFocusValue.trim()
      if (!value) {
        return
      }

      if (!state.customFocusEntries.includes(value)) {
        state.customFocusEntries = [...state.customFocusEntries, value]
      }

      state.selectedFocuses = Array.from(new Set([...state.selectedFocuses.filter((item) => item !== CUSTOM_FOCUS), value]))
      state.customFocusValue = ''
      syncPersistedState()
      markNeedsRerank()
      render()
      return
    }

    if (action === 'open-original') {
      const messageId = target.dataset.messageId
      const threadId = target.dataset.threadId
      const senderName = target.dataset.senderName
      const subject = target.dataset.subject
      if (!messageId || !threadId) {
        return
      }

      const mail = getSourceMailItems().find((item) => item.messageId === messageId || item.threadId === threadId)
      if (mail) {
        state.clickCounts = {
          ...state.clickCounts,
          [mail.senderName]: (state.clickCounts[mail.senderName] ?? 0) + 1,
        }
        const previous = state.analysisHistory[mail.messageId]
        state.analysisHistory[mail.messageId] = {
          ...(previous ?? {
            messageId: mail.messageId,
            threadId: mail.threadId,
            senderName: mail.senderName,
            senderEmail: mail.senderEmail,
            subject: mail.subject,
            briefSubject: mail.briefSubject,
            summary: mail.summary,
            aiSummary: mail.aiSummary,
            aiReason: mail.aiReason,
            actionLabel: mail.actionLabel,
            reasonTags: mail.reasonTags,
            focusAreas: mail.focusAreas,
            aggregationKey: mail.aggregationKey,
            aggregationLabel: undefined,
            priority: mail.priority,
            tab: mail.tab,
            isHighPriority: mail.isHighPriority,
            isTodo: mail.isTodo,
            isDueSoon: mail.isDueSoon,
            isIgnorable: mail.isIgnorable,
            sortScore: mail.sortScore,
            deadlineLabel: mail.deadlineLabel,
            processed: false,
            lastAnalyzedAt: new Date().toISOString(),
          }),
          openedCount: (previous?.openedCount ?? 0) + 1,
        }
        syncPersistedState()
      }

      if (openOriginalMail(messageId, threadId, senderName, subject)) {
        render()
      }
      return
    }

    if (action === 'mark-done') {
      const messageId = target.dataset.messageId
      if (!messageId) {
        return
      }

      const mail = getSourceMailItems().find((item) => item.messageId === messageId)
      if (mail) {
        state.clickCounts = {
          ...state.clickCounts,
          [mail.senderName]: (state.clickCounts[mail.senderName] ?? 0) + 1,
        }
        state.processedMessageIds = Array.from(new Set([...state.processedMessageIds, messageId]))
        const previous = state.analysisHistory[messageId]
        state.analysisHistory[messageId] = {
          ...(previous ?? {
            messageId: mail.messageId,
            threadId: mail.threadId,
            senderName: mail.senderName,
            senderEmail: mail.senderEmail,
            subject: mail.subject,
            briefSubject: mail.briefSubject,
            summary: mail.summary,
            aiSummary: mail.aiSummary,
            aiReason: mail.aiReason,
            actionLabel: mail.actionLabel,
            reasonTags: mail.reasonTags,
            focusAreas: mail.focusAreas,
            aggregationKey: mail.aggregationKey,
            aggregationLabel: undefined,
            priority: mail.priority,
            tab: mail.tab,
            isHighPriority: mail.isHighPriority,
            isTodo: mail.isTodo,
            isDueSoon: mail.isDueSoon,
            isIgnorable: mail.isIgnorable,
            sortScore: mail.sortScore,
            deadlineLabel: mail.deadlineLabel,
            openedCount: 0,
            lastAnalyzedAt: new Date().toISOString(),
          }),
          processed: true,
        }
        syncPersistedState()
        render()
      }
      return
    }

    if (action === 'resummarize-mail') {
      const messageId = target.dataset.messageId
      if (!messageId || state.resummarizingMessageIds.includes(messageId)) {
        return
      }

      state.resummarizingMessageIds = [...state.resummarizingMessageIds, messageId]
      queueViewportRestore({ cardId: `mail:${messageId}`, behavior: 'preserve' })
      render()

      void sendRuntimeMessage({
        type: 'LMA_REFRESH_MAIL_SUMMARY',
        messageId,
        hints: {
          ...buildSyncHints('incremental'),
          analysisMode: 'resummary',
          recentHistory: (() => {
            const currentMail = getSourceMailItems().find((item) => item.messageId === messageId)
            const previousHistoryEntry = state.analysisHistory[messageId]
            if (!currentMail) {
              return []
            }

            return [
              state.analysisHistory[messageId] ?? {
                messageId: currentMail.messageId,
                threadId: currentMail.threadId,
                senderName: currentMail.senderName,
                senderEmail: currentMail.senderEmail,
                subject: currentMail.subject,
                briefSubject: currentMail.briefSubject,
                summary: currentMail.summary,
                aiSummary: currentMail.aiSummary,
                aiReason: currentMail.aiReason,
                deadlineLabel: currentMail.deadlineLabel,
                actionLabel: currentMail.actionLabel,
                reasonTags: currentMail.reasonTags,
                focusAreas: currentMail.focusAreas,
                aggregationKey: currentMail.aggregationKey,
                aggregationLabel: currentMail.aggregationLabel,
                priority: currentMail.priority,
                tab: currentMail.tab,
                isHighPriority: currentMail.isHighPriority,
                isTodo: currentMail.isTodo,
                isDueSoon: currentMail.isDueSoon,
                isIgnorable: currentMail.isIgnorable,
                sortScore: currentMail.sortScore,
                openedCount: state.clickCounts[currentMail.senderName] ?? 0,
                processed: state.processedMessageIds.includes(currentMail.messageId),
                feedback: previousHistoryEntry?.feedback,
                lastAnalyzedAt: new Date().toISOString(),
              },
            ]
          })(),
        },
      }).then((response) => {
        state.resummarizingMessageIds = state.resummarizingMessageIds.filter((id) => id !== messageId)

        if (response.accountKey) {
          state.currentAccountKey = response.accountKey
          persistedStore.lastAccountKey = response.accountKey
          applyPersistedAccountState(getPersistedAccountState(response.accountKey))
        }

        if (response.ok && response.payload?.items?.[0]) {
          const item = response.payload.items[0]
          const currentMail = getSourceMailItems().find((mail) => mail.messageId === item.messageId)
          const updatedMail: MailItem = {
            messageId: item.messageId,
            threadId: item.threadId ?? item.messageId,
            senderName: item.senderName,
            senderEmail: item.senderEmail ?? undefined,
            subject: item.subject,
            briefSubject: item.briefSubject?.trim() || truncateText(cleanSubjectLine(item.subject), 18) || '鏂伴偖浠?,
            summary: item.summary,
            aiSummary: item.aiSummary,
            aiReason: item.aiReason ?? '',
            deadlineLabel: item.deadlineLabel ?? undefined,
            timeText: item.timeText ?? '鏈€杩?,
            priority: currentMail?.priority ?? item.priority,
            tab: currentMail?.tab ?? item.tab,
            isHighPriority: currentMail?.isHighPriority ?? Boolean(item.isHighPriority ?? item.priority === 'high'),
            isTodo: currentMail?.isTodo ?? Boolean(item.isTodo ?? item.tab === 'todo'),
            isDueSoon: currentMail?.isDueSoon ?? Boolean(item.isDueSoon ?? item.tab === 'due_soon'),
            isIgnorable: currentMail?.isIgnorable ?? Boolean(item.isIgnorable ?? item.tab === 'ignorable'),
            actionLabel: currentMail?.actionLabel ?? item.actionLabel ?? undefined,
            reasonTags: item.reasonTags,
            focusAreas: item.focusAreas,
            aggregationKey: currentMail?.aggregationKey ?? item.aggregationKey ?? undefined,
            aggregationLabel: currentMail?.aggregationLabel ?? item.aggregationLabel ?? undefined,
            sortScore: currentMail?.sortScore ?? item.sortScore ?? undefined,
          }

          replaceMailItem(updatedMail)
          syncAnalysisHistory([updatedMail], response.payload.generatedAt)
          state.syncError = ''
          state.syncStatusMessage = response.message ?? '宸查噸鏂版杩板綋鍓嶉偖浠?
          syncPersistedState()
        } else {
          state.syncError = response.error ?? '閲嶆柊姒傝堪澶辫触'
        }

        render()
      })
      return
    }

    if (action === 'feedback-important') {
      const senderName = target.dataset.senderName
      const messageId = target.dataset.messageId
      if (senderName) {
        if (messageId) {
          preferredFollowCardId = `mail:${messageId}`
          queueViewportRestore({ cardId: preferredFollowCardId, behavior: 'preserve' })
        }
        if (messageId) {
          const mail = getSourceMailItems().find((item) => item.messageId === messageId)
          if (mail) {
            queuePriorityUpgrade(mail)
          }
        }
        applyFeedbackAndRerank(senderName, messageId, 'important', 'important')
        render()
      }
      return
    }

    if (action === 'feedback-not-important') {
      const senderName = target.dataset.senderName
      const messageId = target.dataset.messageId
      if (senderName) {
        if (messageId) {
          preferredFollowCardId = `mail:${messageId}`
          queueViewportRestore({ cardId: preferredFollowCardId, behavior: 'preserve' })
        }
        applyFeedbackAndRerank(senderName, messageId, 'not_important', 'not_important')
        render()
      }
      return
    }

    if (action === 'feedback-less') {
      const senderName = target.dataset.senderName
      const messageId = target.dataset.messageId
      if (senderName) {
        if (messageId) {
          preferredFollowCardId = `mail:${messageId}`
          queueViewportRestore({ cardId: preferredFollowCardId, behavior: 'preserve' })
        }
        applyFeedbackAndRerank(senderName, messageId, 'muted', 'less')
        render()
      }
      return
    }

    if (action === 'feedback-hide') {
      const messageId = target.dataset.messageId
      if (messageId) {
        preferredFollowCardId = `mail:${messageId}`
        queueViewportRestore({ cardId: preferredFollowCardId, behavior: 'preserve' })
        scheduleHideToIgnorable(messageId)
        render()
      }
      return
    }

    if (action === 'auth-gmail') {
      void sendRuntimeMessage({ type: 'LMA_AUTH_GMAIL' }).then((response) => {
        if (response.accountKey) {
          const accountChanged = state.currentAccountKey !== null && state.currentAccountKey !== response.accountKey
          if (accountChanged) {
            state.analysisItems = []
            state.syncEngine = null
            state.syncedMailCount = 0
          }
          state.currentAccountKey = response.accountKey
          persistedStore.lastAccountKey = response.accountKey
          applyPersistedAccountState(getPersistedAccountState(response.accountKey))
        }
        state.requiresAuth = Boolean(response.requiresAuth && !response.ok && !state.analysisItems.length)
        state.syncError = response.error ?? ''
        state.syncStatusMessage = response.message ?? ''
        render()

        if (response.ok) {
          void syncAnalysis('refresh')
        }
      })
      return
    }


    if (action === 'refresh-sync') {
      tryStartSyncAnalysis('refresh')
      return
    }

    if (action === 'rerank-analysis') {
      tryStartSyncAnalysis('rerank')
      return
    }
  })

  root.addEventListener('input', (event) => {
    const target = event.target as HTMLInputElement

    if (target.dataset.action === 'custom-sender-input') {
      state.customSenderValue = target.value
      return
    }

    if (target.dataset.action === 'custom-focus-input') {
      state.customFocusValue = target.value
    }
  })

  root.addEventListener('keydown', (event) => {
    const target = event.target as HTMLInputElement
    if (event.key !== 'Enter') {
      return
    }

    if (target.dataset.action === 'custom-sender-input') {
      event.preventDefault()
      root?.querySelector<HTMLElement>('[data-action="add-custom-sender"]')?.click()
      return
    }

    if (target.dataset.action === 'custom-focus-input') {
      event.preventDefault()
      root?.querySelector<HTMLElement>('[data-action="add-custom-focus"]')?.click()
    }
  })

  return root
}

const render = () => {
  const root = ensureRoot()
  if (!queuedViewportAnchor) {
    queueViewportRestore({ behavior: 'preserve' })
  }
  const previousRects = captureCardRects(root)
  const viewportSnapshot = captureViewportSnapshot(root)
  const mailCount = state.syncedMailCount || getSourceMailItems().length
  const syncLine = state.syncEngine
    ? state.syncEngine === 'llm'
      ? `宸茬敤 LLM 鍒嗘瀽 ${mailCount} 灏侀偖浠禶
      : `褰撳墠鐢辫鍒欏紩鎿庡垎鏋?${mailCount} 灏侀偖浠禶
    : mailCount
      ? `宸插悓姝ュ綋鍓嶅垪琛?${mailCount} 灏侀偖浠禶
      : '褰撳墠椤甸潰娌℃湁鍙彁鍙栫殑閭欢鍒楄〃'

  root.innerHTML = `
    <div class="lma-ext-shell ${state.isOpen ? 'is-open' : ''}">
      <button class="lma-ext-launcher" data-action="toggle-panel" type="button">
        <span class="lma-ext-launcher-icon">AI</span>
        <span class="lma-ext-launcher-copy">閲嶇偣鍔╂墜</span>
      </button>
      <aside class="lma-ext-panel ${state.isOpen ? 'is-open' : ''}">
        <header class="lma-ext-header">
          <div>
            <p>閭欢閲嶇偣鍔╂墜</p>
            <div class="lma-ext-title-row">
              <h2>甯綘鍏堢湅閲嶈鐨?/h2>
              <span class="lma-ext-title-meta">${syncLine}</span>
            </div>
          </div>
          <button class="lma-ext-close" data-action="close-panel" type="button">脳</button>
        </header>
        ${renderListView()}
      </aside>
    </div>
  `

  restoreViewportSnapshot(root, viewportSnapshot)
  bindContentScrollFade(root)
  bindLiquidGlass(root)
  animateCardReflow(root, previousRects)
  runViewportFollow(root)
}

let lastMailListSignature = ''

const refreshWhenMailListChanges = () => {
  const nextSignature = getMailListSignature()

  if (nextSignature === lastMailListSignature) {
    return
  }

  lastMailListSignature = nextSignature

  if (state.isOpen) {
    if (state.syncEngine || state.requiresAuth) {
      void syncAnalysis('refresh')
      return
    }

    render()
  }
}

if (!bootstrapWindow.__LMA_EXT_BOOTSTRAPPED__) {
  bootstrapWindow.__LMA_EXT_BOOTSTRAPPED__ = true

  for (const staleRoot of Array.from(document.querySelectorAll<HTMLElement>(`#${ROOT_ID}`))) {
    staleRoot.remove()
  }

  chromeApi?.runtime?.onMessage?.addListener((message: RuntimeMessage, _sender, sendResponse) => {
    if (message.type !== 'LMA_TOGGLE_PANEL') {
      return
    }

    if (state.isOpen) {
      state.isOpen = false
      render()
    } else {
      void openPanel()
    }
    sendResponse({
      ok: true,
      message: state.isOpen ? '宸插睍寮€鍙充晶鍔╂墜銆? : '宸叉敹璧峰彸渚у姪鎵嬨€?,
    })
  })

  const observer = new MutationObserver(() => {
    refreshWhenMailListChanges()
  })

  observer.observe(document.body, { childList: true, subtree: true })
  lastMailListSignature = getMailListSignature()
  loadPersistedState()
  render()
}
