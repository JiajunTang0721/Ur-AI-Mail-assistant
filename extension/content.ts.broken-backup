const extractDeadlineLabel = (text: string) => {
  const cleaned = text.replace(/\s+/g, ' ').trim()
  const patterns = [
    /((?:浠婂ぉ|浠婃櫄|鏄庡ぉ|鏈懆[涓€浜屼笁鍥涗簲鍏棩澶?)[^锛屻€傦紱\n]{0,10}(?:\d{1,2}:\d{2})?)/,
    /((?:4|04)\/\d{1,2}(?:\s*\d{1,2}:\d{2})?)/,
    /((?:\d{1,2}:\d{2})\s*(?:鍓峾鍐厊鎴)?)/,
    /((?:48h|48 hours|48灏忔椂鍐?)/i,
    /((?:by|before|due)\s+[A-Za-z0-9/: ]{2,20})/i,
  ]

  for (const pattern of patterns) {
    const match = cleaned.match(pattern)
    if (match?.[1]) {
      return truncateText(match[1].trim(), 18)
    }
  }

  return undefined
}

