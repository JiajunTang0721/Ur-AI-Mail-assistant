const rerankMailLocally = (mail: MailItem): MailItem => {
  const selectedSenders = getSelectedSenderHints()
  const selectedFocuses = getSelectedFocusHints()
  const haystack = `${mail.senderName} ${mail.senderEmail ?? ''} ${mail.subject} ${mail.summary} ${mail.aiSummary} ${
    mail.aiReason
  } ${mail.reasonTags.join(' ')} ${mail.focusAreas.join(' ')} ${mail.deadlineLabel ?? ''} ${mail.actionLabel ?? ''} ${mail.timeText}`
  const normalizedHaystack = normalize(haystack)
  const normalizedSender = normalize(`${mail.senderName} ${mail.senderEmail ?? ''}`)
  const senderProfile = getSenderProfiles().find((profile) => profile.senderName === mail.senderName)
  const senderPreference = getSenderPreference(mail.senderName)
  const senderMatched = selectedSenders.some((sender) => {
    const normalized = normalize(sender)
    return normalizedSender.includes(normalized)
  })
  const focusMatchCount = selectedFocuses.filter((focus) => {
    const normalized = normalize(focus)
    return (
      normalizedHaystack.includes(normalized) ||
      mail.focusAreas.some((area) => normalize(area).includes(normalized) || normalized.includes(normalize(area)))
    )
  }).length
  const actionLabel = mail.actionLabel ?? getActionLabel(haystack)
  const hasDeadline = Boolean(mail.deadlineLabel) || includesKeyword(haystack, DUE_KEYWORDS)
  const lowSignal = includesKeyword(haystack, LOW_KEYWORDS)
  const isManuallyHidden = state.hiddenMessageIds.includes(mail.messageId)

  if (isManuallyHidden) {
    return {
      ...mail,
      priority: 'low',
      tab: 'ignorable',
      isHighPriority: false,
      isTodo: false,
      isDueSoon: false,
      isIgnorable: true,
      sortScore: 6,
    }
  }

  let score = mail.priority === 'high' ? 62 : mail.priority === 'medium' ? 38 : 14

  if (actionLabel) score += 18
  if (hasDeadline) score += 16
  if (includesKeyword(haystack, HIGH_KEYWORDS)) score += 12
  if (senderMatched) score += 34
  if (focusMatchCount) score += focusMatchCount * 28

  if (senderPreference === 'important') score += 22
  if (senderPreference === 'not_important') score -= 18
  if (senderPreference === 'muted') score -= 34

  if (senderProfile) {
    score += Math.min(12, senderProfile.openedCount * 2)
    score += senderProfile.importantVotes * 6
    score -= senderProfile.notImportantVotes * 5
    score -= senderProfile.mutedVotes * 8
  }

  let priority: Priority = 'low'
  let tab: TabKey = 'ignorable'
  let isHighPriority = false
  let isTodo = false
  let isDueSoon = false
  let isIgnorable = false

  if (lowSignal && !actionLabel && !hasDeadline && !senderMatched && !focusMatchCount) {
    priority = 'low'
    tab = 'ignorable'
    isIgnorable = true
  } else if (hasDeadline || includesKeyword(haystack, DUE_KEYWORDS)) {
    priority = score >= 78 ? 'high' : 'medium'
    tab = 'due_soon'
    isDueSoon = true
    isTodo = true
    isHighPriority = priority === 'high'
  } else if (score >= 84) {
    priority = 'high'
    tab = 'today_focus'
    isHighPriority = true
    isTodo = true
  } else if (score >= 44) {
    priority = 'medium'
    tab = 'todo'
    isTodo = true
  } else {
    isIgnorable = true
  }

  return {
    ...mail,
    priority,
    tab,
    isHighPriority,
    isTodo,
    isDueSoon,
    isIgnorable,
    sortScore: score,
  }
}

