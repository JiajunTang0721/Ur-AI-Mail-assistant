const ensureAccountContext = async () => {
  const response = await sendRuntimeMessage({ type: 'LMA_GET_GMAIL_AUTH_STATE' })

  if (response.accountKey) {
    const accountChanged = state.currentAccountKey !== null && state.currentAccountKey !== response.accountKey
    if (accountChanged) {
      state.analysisItems = []
      state.syncEngine = null
      state.syncedMailCount = 0
    }
    state.currentAccountKey = response.accountKey
    persistedStore.lastAccountKey = response.accountKey
    applyPersistedAccountState(getPersistedAccountState(response.accountKey))
    applyCachedAnalysisIfFresh()
  }

  if (!response.ok && response.requiresAuth) {
    state.requiresAuth = !state.analysisItems.length
  }

  return response
}

const openPanel = async () => {
  state.isOpen = true
  render()

  if (!state.preferencesLoaded) {
    return
  }

  await ensureAccountContext()

  if (applyCachedAnalysisIfFresh()) {
    render()
    return
  }

  if (state.analysisItems.length && state.syncEngine && getMailListSignature() === getPersistedAccountState().analysisCache?.mailSignature) {
    render()
    return
