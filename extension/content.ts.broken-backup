const migratePersistedStore = (raw: unknown): PersistedStore => {
  if (!raw || typeof raw !== 'object') {
    return {
      version: STORAGE_VERSION,
      accounts: {},
    }
  }

  const candidate = raw as Partial<PersistedStore & PersistedState>

  if (candidate.accounts && typeof candidate.accounts === 'object') {
    const nextAccounts = Object.fromEntries(
      Object.entries(candidate.accounts).map(([accountKey, value]) => [
        accountKey,
        normalizePersistedState(value as Partial<PersistedState>),
      ]),
    )

    return {
      version: STORAGE_VERSION,
      lastAccountKey: candidate.lastAccountKey,
      accounts: nextAccounts,
    }
  }

  return {
    version: STORAGE_VERSION,
    lastAccountKey: DEFAULT_ACCOUNT_KEY,
    accounts: {
      [DEFAULT_ACCOUNT_KEY]: normalizePersistedState(candidate as Partial<PersistedState>),
    },
  }
}

