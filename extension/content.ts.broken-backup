const findCardById = (root: HTMLElement, cardId: string) =>
  Array.from(root.querySelectorAll<HTMLElement>('[data-card-id]')).find(
    (element) => element.dataset.cardId === cardId,
  )

const queueViewportRestore = (anchor: ViewportAnchor = {}) => {
  queuedViewportAnchor = {
    cardId: anchor.cardId,
    behavior: anchor.behavior ?? 'preserve',
  }
}

const captureViewportSnapshot = (root: HTMLElement): ViewportSnapshot | null => {
  const content = root.querySelector<HTMLElement>('.lma-ext-content')
  if (!content) {
    return null
  }

  const snapshot: ViewportSnapshot = {
    scrollTop: content.scrollTop,
    followBehavior: queuedViewportAnchor?.behavior ?? 'preserve',
  }

  const anchorCardId = queuedViewportAnchor?.cardId
  if (anchorCardId) {
    const anchorCard = findCardById(root, anchorCardId)
    if (anchorCard) {
      snapshot.anchorCardId = anchorCardId
      snapshot.anchorViewportOffset =
        anchorCard.getBoundingClientRect().top - content.getBoundingClientRect().top
    }
  }

  return snapshot
}

const restoreViewportSnapshot = (root: HTMLElement, snapshot: ViewportSnapshot | null) => {
  const content = root.querySelector<HTMLElement>('.lma-ext-content')
  if (!content || !snapshot) {
    queuedViewportAnchor = null
    pendingViewportFollow = null
    return
  }

  content.scrollTop = snapshot.scrollTop

  if (snapshot.anchorCardId && typeof snapshot.anchorViewportOffset === 'number') {
    const anchorCard = findCardById(root, snapshot.anchorCardId)
    if (anchorCard) {
      if (snapshot.followBehavior === 'follow') {
        pendingViewportFollow = {
          cardId: snapshot.anchorCardId,
        }
      } else {
        const anchorContentOffset =
          anchorCard.getBoundingClientRect().top - content.getBoundingClientRect().top + content.scrollTop
        const targetScrollTop = Math.max(0, anchorContentOffset - snapshot.anchorViewportOffset)
        content.scrollTop = targetScrollTop
      }
    }
  }

  queuedViewportAnchor = null
}

const runViewportFollow = (root: HTMLElement) => {
  const content = root.querySelector<HTMLElement>('.lma-ext-content')
  if (!content || !pendingViewportFollow) {
    pendingViewportFollow = null
    return
  }

  const anchorCard = findCardById(root, pendingViewportFollow.cardId)
  pendingViewportFollow = null

  if (!anchorCard) {
    return
  }

  const contentRect = content.getBoundingClientRect()
  const cardRect = anchorCard.getBoundingClientRect()
  const cardContentOffset = cardRect.top - contentRect.top + content.scrollTop
  const viewportTarget = Math.max(56, Math.min(content.clientHeight * 0.26, 148))
  const targetScrollTop = Math.max(0, cardContentOffset - viewportTarget)

  if (Math.abs(targetScrollTop - content.scrollTop) < 12) {
    return
  }

  globalThis.requestAnimationFrame(() => {
    content.scrollTo({
      top: targetScrollTop,
      behavior: 'smooth',
    })
  })
}

const animateCardReflow = (root: HTMLElement, previousRects: Map<string, DOMRect>) => {
  for (const card of Array.from(root.querySelectorAll<HTMLElement>('[data-card-id]'))) {
    const cardId = card.dataset.cardId ?? ''
    const previous = previousRects.get(cardId)

    if (!previous) {
      continue
    }

    const current = card.getBoundingClientRect()
    const deltaX = previous.left - current.left
    const deltaY = previous.top - current.top

    if (Math.abs(deltaX) < 1 && Math.abs(deltaY) < 1) {
      continue
    }

    card.animate(
      [
        {
          transform: `translate(${deltaX}px, ${deltaY}px)`,
          boxShadow: '0 18px 34px rgba(43, 122, 242, 0.12)',
        },
        {
          transform: 'translate(0, 0)',
          boxShadow: '0 0 0 rgba(43, 122, 242, 0)',
        },
      ],
      {
        duration: 420,
        easing: 'cubic-bezier(0.22, 1, 0.36, 1)',
      },
    )
  }
}

const bindLiquidGlass = (root: HTMLElement) => {
  const buttons = Array.from(root.querySelectorAll<HTMLElement>('button:not(.lma-ext-overview-card)'))

  buttons.forEach((button) => {
    button.classList.add('lma-ext-liquid-target')
    button.addEventListener('pointerenter', () => {
      button.classList.add('is-liquid-hovered')
    })
    button.addEventListener('pointerleave', () => {
      button.classList.remove('is-liquid-hovered')
    })
    button.addEventListener('pointermove', (event) => {
      const rect = button.getBoundingClientRect()
      button.style.setProperty('--glass-x', `${event.clientX - rect.left}px`)
      button.style.setProperty('--glass-y', `${event.clientY - rect.top}px`)
    })
  })

  const groups = Array.from(
    root.querySelectorAll<HTMLElement>(
      '.lma-ext-actions, .lma-ext-feedback-row, .lma-ext-filter-choice-row, .lma-ext-filter-input-row',
    ),
  )

  groups.forEach((group) => {
    const targets = Array.from(group.querySelectorAll<HTMLElement>('button:not(.lma-ext-overview-card)'))
    if (!targets.length) {
      return
    }

    group.classList.add('lma-ext-liquid-group')

    const indicator = document.createElement('span')
    indicator.className = 'lma-ext-liquid-indicator'
    group.appendChild(indicator)

    const moveIndicator = (target: HTMLElement) => {
      const groupRect = group.getBoundingClientRect()
      const rect = target.getBoundingClientRect()

      indicator.style.width = `${rect.width}px`
      indicator.style.height = `${rect.height}px`
      indicator.style.transform = `translate(${rect.left - groupRect.left}px, ${rect.top - groupRect.top}px)`
      indicator.style.borderRadius = getComputedStyle(target).borderRadius
      indicator.style.opacity = '1'
    }

    const activateTarget = (target: HTMLElement, event?: PointerEvent) => {
      targets.forEach((item) => item.classList.toggle('is-liquid-hovered', item === target))

      if (event) {
        const rect = target.getBoundingClientRect()
        const x = event.clientX - rect.left
        const y = event.clientY - rect.top
        target.style.setProperty('--glass-x', `${x}px`)
        target.style.setProperty('--glass-y', `${y}px`)
        indicator.style.setProperty('--glass-x', `${x}px`)
        indicator.style.setProperty('--glass-y', `${y}px`)
      } else {
        indicator.style.setProperty('--glass-x', `${target.clientWidth / 2}px`)
        indicator.style.setProperty('--glass-y', `${target.clientHeight / 2}px`)
      }

      moveIndicator(target)
    }

    targets.forEach((target) => {
      target.addEventListener('pointerenter', (event) => activateTarget(target, event))
      target.addEventListener('pointermove', (event) => activateTarget(target, event))
    })

    group.addEventListener('pointerleave', () => {
      indicator.style.opacity = '0'
      targets.forEach((target) => target.classList.remove('is-liquid-hovered'))
    })
  })
}

