const syncAnalysis = async (reason: 'open' | 'refresh' | 'rerank' = 'refresh') => {
  state.isSyncing = true
  state.syncStatusMessage =
    reason === 'rerank' ? '姝ｅ湪鎸夋渶鏂板亸濂介噸鏂版帓搴忛偖浠垛€? : '姝ｅ湪鍚屾骞跺垎鏋?Gmail 閭欢鈥?
  queueViewportRestore({ behavior: 'preserve' })
  render()

  const response = await sendRuntimeMessage({
    type: 'LMA_SYNC_GMAIL_ANALYSIS',
    hints: buildSyncHints(reason === 'rerank' ? 'rerank' : 'incremental'),
  })

  state.isSyncing = false
  state.syncError = response.error ?? ''
  if (response.accountKey) {
    const accountChanged = state.currentAccountKey !== null && state.currentAccountKey !== response.accountKey
    if (accountChanged) {
      state.analysisItems = []
      state.syncEngine = null
      state.syncedMailCount = 0
    }
    state.currentAccountKey = response.accountKey
    persistedStore.lastAccountKey = response.accountKey
    applyPersistedAccountState(getPersistedAccountState(response.accountKey))
  }
  state.requiresAuth = Boolean(response.requiresAuth && !state.analysisItems.length)
  state.syncStatusMessage = response.message ?? ''

  if (response.ok && response.payload) {
    applySyncPayload(response.payload)
    if (state.hiddenMessageIds.length) {
      state.analysisItems = state.analysisItems
        .map((mail) => rerankMailLocally(mail))
        .sort((left, right) => (right.sortScore ?? 0) - (left.sortScore ?? 0))
    }
    syncAnalysisHistory(state.analysisItems, response.payload.generatedAt)
    getPersistedAccountState().analysisCache = {
      payload: {
        ...response.payload,
        items: state.analysisItems.map((mail) => serializeMailItem(mail)),
        overview: getOverviewCounts(),
      },
      mailSignature: getMailListSignature(),
      preferenceSignature: getPreferenceSignature(),
      savedAt: new Date().toISOString(),
    }
    if (reason === 'rerank') {
      state.needsRerank = false
    }
    syncPersistedState()
  }

  if (!response.ok && reason === 'rerank' && state.analysisItems.length) {
    rerankAnalysisLocally()
  }

  queueViewportRestore(
    reason === 'rerank' && preferredFollowCardId
      ? { cardId: preferredFollowCardId, behavior: 'follow' }
      : { behavior: 'preserve' },
  )
  render()
}

