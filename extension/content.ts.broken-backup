const getSenderProfiles = (): SenderProfile[] => {
  const profiles = new Map<string, SenderProfile>()

  const ensureProfile = (senderName: string) => {
    const key = senderName.trim()
    const existing = profiles.get(key)
    if (existing) {
      return existing
    }

    const profile: SenderProfile = {
      senderName: key,
      openedCount: 0,
      processedCount: 0,
      importantVotes: 0,
      notImportantVotes: 0,
      mutedVotes: 0,
    }
    profiles.set(key, profile)
    return profile
  }

  Object.entries(state.clickCounts).forEach(([senderName, count]) => {
    ensureProfile(senderName).openedCount = count
  })

  Object.values(state.analysisHistory).forEach((entry) => {
    const profile = ensureProfile(entry.senderName)
    profile.lastPriority = entry.priority
    profile.lastTab = entry.tab
    if (entry.processed) {
      profile.processedCount += 1
    }
    profile.openedCount = Math.max(profile.openedCount, entry.openedCount)
  })

  state.feedbackHistory.forEach((entry) => {
    const profile = ensureProfile(entry.senderName)
    if (entry.preference === 'important') {
      profile.importantVotes += 1
    }
    if (entry.preference === 'not_important') {
      profile.notImportantVotes += 1
    }
    if (entry.preference === 'muted') {
      profile.mutedVotes += 1
    }
  })

  return Array.from(profiles.values())
    .sort(
      (left, right) =>
        right.importantVotes - left.importantVotes ||
        right.openedCount - left.openedCount ||
        right.processedCount - left.processedCount,
    )
    .slice(0, 30)
}

