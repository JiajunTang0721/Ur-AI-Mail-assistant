const groupEntries = (mails: MailItem[]): VisibleEntry[] => {
  const grouped = new Map<string, MailItem[]>()
  const entries: VisibleEntry[] = []
  const visited = new Set<string>()

  mails.forEach((mail) => {
    if (!mail.aggregationKey) {
      entries.push({ kind: 'single', item: mail })
      return
    }

    const existing = grouped.get(mail.aggregationKey) ?? []
    existing.push(mail)
    grouped.set(mail.aggregationKey, existing)
  })

  mails.forEach((mail) => {
    if (!mail.aggregationKey || visited.has(mail.aggregationKey)) {
      return
    }

    visited.add(mail.aggregationKey)
    const items = grouped.get(mail.aggregationKey) ?? [mail]
    entries.push(items.length > 1 ? { kind: 'bundle', key: mail.aggregationKey, items } : { kind: 'single', item: mail })
  })

  return entries
}

