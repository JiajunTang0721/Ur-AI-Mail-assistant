const classifyMail = ({
  text,
  unread,
  actionLabel,
  focusAreas,
  hasDeadline,
  senderPreference,
}: {
  text: string
  unread: boolean
  actionLabel?: string
  focusAreas: string[]
  hasDeadline: boolean
  senderPreference: 'default' | 'important' | 'not_important' | 'muted'
}) => {
  if ((includesKeyword(text, LOW_KEYWORDS) || senderPreference === 'muted') && !actionLabel && !hasDeadline) {
    return {
      priority: 'low' as const,
      tab: 'ignorable' as const,
      isHighPriority: false,
      isTodo: false,
      isDueSoon: false,
      isIgnorable: true,
    }
  }

  let score = 0

  if (actionLabel) score += 3
  if (hasDeadline || includesKeyword(text, DUE_KEYWORDS)) score += 2
  if (includesKeyword(text, HIGH_KEYWORDS)) score += 2
  if (focusAreas.length) score += 1
  if (unread) score += 1
  if (senderPreference === 'important') score += 3
  if (senderPreference === 'not_important') score -= 3
  if (senderPreference === 'muted') score -= 4

  const isDueSoon = hasDeadline || includesKeyword(text, DUE_KEYWORDS)
  const isHighPriority = score >= 4
  const isTodo = Boolean(actionLabel) || isDueSoon || score >= 2
  const priority = isHighPriority ? ('high' as const) : score >= 2 ? ('medium' as const) : ('low' as const)
  const tab = isDueSoon ? ('due_soon' as const) : isHighPriority ? ('today_focus' as const) : isTodo ? ('todo' as const) : ('ignorable' as const)

  return {
    priority,
    tab,
    isHighPriority: tab !== 'ignorable' && isHighPriority,
    isTodo: tab !== 'ignorable' && isTodo,
    isDueSoon: tab !== 'ignorable' && isDueSoon,
    isIgnorable: tab === 'ignorable',
  }
}

