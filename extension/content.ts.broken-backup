    message: '鍙嶉宸茶褰曪紝閭欢灏嗙Щ鍏ュ彲蹇界暐',
    pendingHideUntil,
  })
  render()

  globalThis.setTimeout(() => {
    const current = state.feedbackAcknowledgements[messageId]
    if (!current || current.pendingHideUntil !== pendingHideUntil) {
      return
    }

    state.removingMessageIds = Array.from(new Set([...state.removingMessageIds, messageId]))
    render()

    globalThis.setTimeout(() => {
      clearFeedbackAcknowledgement(messageId)
      state.removingMessageIds = state.removingMessageIds.filter((id) => id !== messageId)
      moveMailToIgnorable(messageId)
      render()
    }, 520)
  }, 3000)
}

const openOriginalMail = (messageId: string, threadId: string, senderName?: string, subject?: string) => {
  const allRows = Array.from(document.querySelectorAll<HTMLElement>('tr.zA'))

  const row =
    document.querySelector<HTMLElement>(`tr.zA[data-legacy-message-id="${messageId}"]`) ??
    document.querySelector<HTMLElement>(`tr.zA[data-legacy-thread-id="${threadId}"]`) ??
    allRows.find((candidate) => {
      const candidateSender = normalize(
        extractText(candidate.querySelector<HTMLElement>('.yP')) ||
          extractText(candidate.querySelector<HTMLElement>('.yW')),
      )
      const candidateSubject = normalize(
        extractText(candidate.querySelector<HTMLElement>('.bog')) ||
          extractText(candidate.querySelector<HTMLElement>('.y6')),
      )

      return (
        Boolean(senderName && candidateSender.includes(normalize(senderName))) &&
        Boolean(subject && candidateSubject.includes(normalize(subject)))
      )
    })

  const gmailThreadUrl = `${window.location.origin}${window.location.pathname}#inbox/${encodeURIComponent(threadId)}`

  if (!row) {
    window.location.assign(gmailThreadUrl)
    return true
  }

  const anchor = row.querySelector<HTMLAnchorElement>('a[href*="#"]')
  const href = anchor?.href?.trim()

  if (href) {
    window.location.assign(href)
    return true
  }

  const clickable =
    row.querySelector<HTMLElement>('td[role="gridcell"] div[role="link"]') ??
    row.querySelector<HTMLElement>('div[role="link"]') ??
    row.querySelector<HTMLElement>('td[role="gridcell"]') ??
    row

  row.scrollIntoView({ block: 'center', behavior: 'smooth' })

  clickable.dispatchEvent(new MouseEvent('mousedown', { bubbles: true, cancelable: true, view: window }))
  clickable.dispatchEvent(new MouseEvent('mouseup', { bubbles: true, cancelable: true, view: window }))
  clickable.dispatchEvent(new MouseEvent('click', { bubbles: true, cancelable: true, view: window }))

  return true
}

const bindContentScrollFade = (root: HTMLElement) => {
  const shell = root.querySelector<HTMLElement>('.lma-ext-content-shell')
  const content = root.querySelector<HTMLElement>('.lma-ext-content')

  if (!shell || !content) {
    return
  }

  const updateFade = () => {
    shell.classList.toggle('is-scrolled', content.scrollTop > 6)
  }

  updateFade()
  content.addEventListener('scroll', updateFade, { passive: true })
}

