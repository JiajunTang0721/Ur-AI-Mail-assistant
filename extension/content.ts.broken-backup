const applySenderFeedback = (
  senderName: string,
  preference: 'important' | 'not_important' | 'muted',
) => {
  state.importantSenderNames = state.importantSenderNames.filter((item) => item !== senderName)
  state.notImportantSenderNames = state.notImportantSenderNames.filter((item) => item !== senderName)
  state.mutedSenderNames = state.mutedSenderNames.filter((item) => item !== senderName)

  if (preference === 'important') {
    state.importantSenderNames = [...state.importantSenderNames, senderName]
  }

  if (preference === 'not_important') {
    state.notImportantSenderNames = [...state.notImportantSenderNames, senderName]
  }

  if (preference === 'muted') {
    state.mutedSenderNames = [...state.mutedSenderNames, senderName]
  }

  state.feedbackHistory = [
    {
      senderName,
      preference,
      updatedAt: new Date().toISOString(),
    },
    ...state.feedbackHistory.filter((entry) => entry.senderName !== senderName),
  ].slice(0, 200)

  Object.values(state.analysisHistory).forEach((entry) => {
    if (entry.senderName === senderName) {
      state.analysisHistory[entry.messageId] = {
        ...entry,
        feedback: preference,
      }
    }
  })

  syncPersistedState()
}

