const scheduleSyncCooldownRender = () => {
  if (syncCooldownTimer !== null) {
    window.clearTimeout(syncCooldownTimer)
    syncCooldownTimer = null
  }

  const remainingMs = getSyncCooldownRemainingMs()
  if (!remainingMs) {
    return
  }

  syncCooldownTimer = window.setTimeout(() => {
    syncCooldownTimer = null
    render()
    scheduleSyncCooldownRender()
  }, Math.min(1000, remainingMs))
}

const startSyncCooldown = () => {
  state.syncCooldownUntil = Date.now() + SYNC_ACTION_COOLDOWN_MS
  scheduleSyncCooldownRender()
}

